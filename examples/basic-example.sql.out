 pglt_01K89DGA1YEYF9G7KMH0HBSE36 | pgla_01K89DGA1PFQ29VGZHSJQ985MA | pgla_01K89DGA1QEE3R6CX8N6JSM0YT |   8.00 | 2025-10-23 20:52:27.326302+00 | 2025-01-01 00:00:00+00
(2 rows)

SELECT * FROM pgledger_create_transfers(
    transfer_requests => array[
    (:'user1_external_id',:'user1_receivables_id', 10.00),
    (:'user1_receivables_id',:'user1_available_id', 8.00)
    ]::TRANSFER_REQUEST [],
    event_at => '2025-01-01',
    metadata => '{"a": "b"}'
);
